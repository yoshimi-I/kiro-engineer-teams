layout {
    tab name="Pipeline" {
        pane split_direction="horizontal" {
            pane split_direction="vertical" {
                pane command="bash" name="Impl-1" {
                    args "-c" "./scripts/agent.sh implement"
                }
                pane command="bash" name="Impl-2" {
                    args "-c" "./scripts/agent.sh implement"
                }
                pane command="bash" name="Review" {
                    args "-c" "./scripts/agent.sh review"
                }
                pane command="bash" name="Fix-Review" {
                    args "-c" "./scripts/agent.sh fix-review-issues"
                }
            }
            pane split_direction="vertical" {
                pane command="bash" name="Fix-CI" {
                    args "-c" "./scripts/agent.sh fix-ci"
                }
                pane command="bash" name="Watch-Main" {
                    args "-c" "./scripts/agent.sh watch-main"
                }
                pane command="bash" name="E2E-Hunt" {
                    args "-c" "./scripts/agent.sh e2e-bug-hunt"
                }
                pane command="bash" name="Dependabot" {
                    args "-c" "./scripts/agent.sh auto-dependabot"
                }
            }
        }
    }
    tab name="Status" {
        pane command="bash" name="task.md" {
            args "-c" "watch -n 5 'cat issue/task.md 2>/dev/null || echo No task.md yet'"
        }
    }
}
